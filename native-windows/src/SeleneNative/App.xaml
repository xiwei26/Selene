<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="SeleneNative.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SeleneNative">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <!-- Overrides for dark theme colors -->
                    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#000000" />
                    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#CC0D150E" />
                    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#CC0D150E" />
                    <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="#CC0D150E" />
                    
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#DCE5D9" />
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#BBCBBA" />
                    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#12C866" />
                    <SolidColorBrush x:Key="SystemAccentColor" Color="#12C866" />
                    
                    <!-- Buttons -->
                    <SolidColorBrush x:Key="ButtonBackground" Color="#1A221A" />
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#3C4A3D" />
                    <SolidColorBrush x:Key="ButtonForeground" Color="#DCE5D9" />
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#242C24" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#2F372F" />

                    <!-- TextBox -->
                    <SolidColorBrush x:Key="TextControlBackground" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0D0D0D" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#050505" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#12C866" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#556254" />

                    <!-- ProgressBar -->
                    <SolidColorBrush x:Key="ProgressBarIndicatorForeground" Color="#12C866" />
                    <SolidColorBrush x:Key="ProgressBarTrackBackground" Color="#2F372F" />
                </ResourceDictionary>
                
                <ResourceDictionary x:Key="Dark">
                    <!-- Same Dark overrides -->
                    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#000000" />
                    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#CC0D150E" />
                    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#CC0D150E" />
                    <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="#CC0D150E" />
                    
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="#DCE5D9" />
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#BBCBBA" />
                    <SolidColorBrush x:Key="SystemControlHighlightAccentBrush" Color="#12C866" />
                    <SolidColorBrush x:Key="SystemAccentColor" Color="#12C866" />
                    
                    <!-- Buttons -->
                    <SolidColorBrush x:Key="ButtonBackground" Color="#1A221A" />
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#3C4A3D" />
                    <SolidColorBrush x:Key="ButtonForeground" Color="#DCE5D9" />
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#242C24" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#2F372F" />

                    <!-- TextBox -->
                    <SolidColorBrush x:Key="TextControlBackground" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0D0D0D" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#050505" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#12C866" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#556254" />

                    <!-- ProgressBar -->
                    <SolidColorBrush x:Key="ProgressBarIndicatorForeground" Color="#12C866" />
                    <SolidColorBrush x:Key="ProgressBarTrackBackground" Color="#2F372F" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
